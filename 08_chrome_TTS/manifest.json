{
  "manifest_version": 3,
  "name": "Google Cloud TTS & STT Tool",
  "version": "1.0",
  "description": "A Chrome extension for Text-to-Speech and Speech-to-Text using Google Cloud APIs.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabCapture",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "https://texttospeech.googleapis.com/*",
    "https://speech.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
