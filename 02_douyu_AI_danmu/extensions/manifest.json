{
  "manifest_version": 3,
  "name": "Douyu Danmu Sender",
  "version": "1.0",
  "description": "在指定的文本框中输入内容，然后点击指定按钮",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.douyu.com/*"],
      "js": ["config.js", "content.js"]
    }
  ],
  "host_permissions": [
    "https://www.douyu.com/*",
    "https://generativelanguage.googleapis.com/*"
  ]
}
